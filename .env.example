# ─────────────────────────────────────────────
# ALMDS Environment Configuration Template
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ─────────────────────────────────────────────

# ── Serial / MAVLink ──────────────────────────
# Serial port connecting Raspberry Pi to flight controller
MAVLINK_PORT=/dev/ttyAMA0
MAVLINK_BAUD=921600

# ── GSM / 4G (SIM7600G-H) ────────────────────
# Serial port for the SIM7600G-H module
GSM_PORT=/dev/ttyUSB2
GSM_BAUD=115200

# ── Camera ───────────────────────────────────
# CSI camera indices (0 = Camera 1 dock, 1 = Camera 2 in-flight)
CAMERA_DOCK_INDEX=0
CAMERA_INFLIGHT_INDEX=1

# ── Servo GPIO Pins ───────────────────────────
# BCM pin numbers for MG995 servos
SERVO_CARGO_DOOR_PIN=18
SERVO_PAYLOAD_DROP_PIN=23

# ── Mission Parameters ────────────────────────
# Safe cruising altitude in metres AGL
CRUISE_ALTITUDE_M=15

# Minimum battery voltage before arming is blocked
MIN_BATTERY_VOLTAGE=14.2

# ── Dashboard / API ───────────────────────────
# Flask API host and port (operator dashboard interface)
API_HOST=0.0.0.0
API_PORT=5000

# Dashboard backend URL for delivery record validation
DASHBOARD_URL=http://192.168.1.100:8080
DASHBOARD_API_KEY=your_api_key_here

# ── Customer Notification ─────────────────────
# Sender ID shown on SMS (max 11 chars, alphanumeric)
SMS_SENDER_ID=ALMDS

# ── ToF Sensor ────────────────────────────────
# I2C bus number for VL53L8CH
TOF_I2C_BUS=1
TOF_I2C_ADDRESS=0x29

# Target hover height above drop-box before payload release (cm)
TOF_DROP_HEIGHT_CM=80
